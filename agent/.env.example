# ===== 大模型 API 配置（OpenAI 兼容接口）=====
# 默认示例为 DeepSeek，可替换为任意 OpenAI 兼容端点（通义、Moonshot、OpenAI 等）

# API 密钥（必填）
LLM_API_KEY=sk-your-api-key-here

# API 基础地址
# DeepSeek:   https://api.deepseek.com/v1
# 通义千问:    https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI:     https://api.openai.com/v1
# Moonshot:   https://api.moonshot.cn/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# 模型名称
# DeepSeek: deepseek-chat   通义: qwen-plus   OpenAI: gpt-4o
LLM_MODEL=deepseek-chat

# ===== 知识库配置 =====
# 知识库目录（相对本项目根目录）。新库 data/knowledge/concepts/ 优先加载（方法百科页 schema_version=3）
KNOWLEDGE_DIR=data/knowledge

# 检索返回的知识单元数量
RETRIEVAL_TOP_K=5
# 检索相对阈值：保留得分 >= 最高分 * RATIO 的结果
RETRIEVAL_RELATIVE_RATIO=0.4
# 检索绝对下限：最高分低于此值则判为「超出知识库范围」
RETRIEVAL_ABS_FLOOR=2.0
# 旧的绝对阈值（已由相对阈值取代，保留兼容）
RETRIEVAL_MIN_SCORE=3.0

# ===== 上传文件配置 =====
# 单文件大小上限（字节，默认 10MB）
UPLOAD_MAX_BYTES=10485760

# ===== 代码执行配置 =====
# 单次代码执行超时（秒）
CODE_TIMEOUT=30
# 出错后自动迭代修正的最大次数
MAX_CODE_ITERATIONS=3

# ===== 内置计费网关（新手一键领取免费额度） =====
# 如果你部署了 gateway/，填写你的网关地址，新手就能在 app 里一键注册领额度。
# 网关注册/控制台地址（用户在这里注册、领额度、生成 API Key）
GATEWAY_SIGNUP_URL=https://math-modeling.top/dashboard
# 网关的 OpenAI 兼容端点（填到 app 的 Base URL 里）
GATEWAY_BASE_URL=https://math-modeling.top/v1
# 网关默认使用的模型名
GATEWAY_MODEL=deepseek-v4-pro

# ===== 服务配置 =====
HOST=127.0.0.1
PORT=8000
