# ===== 上游 LLM（真正花钱的地方，密钥只存在服务器，绝不下发用户）=====
# 你的 DeepSeek（或其它 OpenAI 兼容厂商）密钥
UPSTREAM_API_KEY=sk-your-real-deepseek-key
# 上游 API 地址（OpenAI 兼容）
UPSTREAM_BASE_URL=https://api.deepseek.com/v1
# 允许用户通过网关调用的模型白名单（逗号分隔，防止借网关调贵模型）
ALLOWED_MODELS=deepseek-v4-pro

# ===== 计费 =====
# 售价倍率：上游成本 × 倍率 = 向用户收的钱
BILLING_MARKUP=2.0
# 新用户注册赠送的免费 token 额度（默认 150 万，可改为 0 关闭赠送）
FREE_TOKENS_ON_SIGNUP=1500000

# ===== 鉴权 / 安全（公网部署务必改）=====
# 登录 token 签名密钥：openssl rand -hex 32
AUTH_SECRET=dev-insecure-change-me
# 登录 token 有效期（秒，默认 30 天）
AUTH_TOKEN_TTL=2592000
# 管理员口令：调 /api/admin/*（手动充值、生成卡密）需在请求头 X-Admin-Token 带此值
ADMIN_TOKEN=dev-admin-change-me

# ===== 服务 =====
HOST=0.0.0.0
PORT=9000
