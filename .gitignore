# ===== 密钥与本地配置（绝不入库）=====
.env
agent/.env
gateway/.env

# ===== Python =====
__pycache__/
*.pyc
.venv/
agent/.venv/
gateway/.venv/

# ===== 运行时产物 / 用户数据 =====
agent/data/conversations/*.json
agent/data/solve_conversations/*.json
agent/data/solve_sessions/*.json
agent/data/dynamic_problems/*.json
agent/data/runs/*/
agent/data/profiles/*.json
# agent/data/assessment/*.json  ← 已取消忽略：题库+学习路径是发布必需的静态数据
agent/data/settings.json
gateway/data/*.db
gateway/data/*.db-shm
gateway/data/*.db-wal

# ===== 日志 =====
*.log
agent/data/app.log
agent/data/srv.*.log

# ===== 打包中间产物与产物 =====
packaging/_work/
packaging/dist/
*.spec

# ===== 编辑器 / 系统 =====
.DS_Store
Thumbs.db
.idea/
.vscode/
